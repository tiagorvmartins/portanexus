    "jest": "^29.2.1",
    "jest-expo": "~54.0.14",
    "metro-react-native-babel-preset": "^0.77.0",
    "react-test-renderer": "19.0.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.8.3"
  },
  "private": true
}
